<UserControl x:Class="ProyectoSoftware.Views.IngenieroRevisorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:viewmodels="clr-namespace:ProyectoSoftware.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:IngenieroRevisorViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Panel de Revisión Técnica" FontSize="28" FontWeight="Bold" Foreground="#1A1A1A"/>
            <TextBlock Text="Actividades asignadas pendientes de tu evaluación" FontSize="14" Foreground="#666666" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1" Color="Black"/>
            </Border.Effect>

            <ui:DataGrid ItemsSource="{Binding ActividadesAsignadas}" 
                         SelectedItem="{Binding ActividadSeleccionada}"
                         AutoGenerateColumns="False" 
                         IsReadOnly="True"
                         HeadersVisibility="Column">

                <ui:DataGrid.Columns>
                    <DataGridTextColumn Header="ID Proyecto" Binding="{Binding IdProyecto}" Width="100"/>
                    <DataGridTextColumn Header="Desarrollador Original" Binding="{Binding IngenieroAsignado.Nombre}" Width="200"/>
                    <DataGridTextColumn Header="Actividad a Revisar" Binding="{Binding NombreActividad}" Width="*"/>

                    <DataGridTemplateColumn Header="Estado" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#FFF4CE" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Estado}" Foreground="#9D5D00" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </ui:DataGrid.Columns>
            </ui:DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <ui:Button Content="Evaluar Actividad" 
                       Command="{Binding AbrirDialogoRevisionCommand}"
                       Icon="Edit24"
                       Appearance="Primary"
                       Padding="20,10" FontSize="14"/>
        </StackPanel>

        <Grid Grid.RowSpan="3" Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#66000000">
                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick" Command="{Binding CerrarDialogoCommand}"/>
                </Border.InputBindings>
            </Border>

            <Border Width="500" Background="White" CornerRadius="12" Padding="25" 
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.3" Color="Black"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Emitir Veredicto Técnico" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#1A1A1A"/>
                    <TextBlock Text="{Binding ActividadSeleccionada.NombreActividad, StringFormat='Evaluando: {0}'}" 
                               FontSize="14" Foreground="#0078D4" FontWeight="Medium" Margin="0,0,0,20"/>

                    <TextBlock Text="Observaciones:" FontWeight="Medium" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding Observaciones, UpdateSourceTrigger=PropertyChanged}" 
                                TextWrapping="Wrap" AcceptsReturn="True" 
                                VerticalScrollBarVisibility="Auto"
                                Height="120" Margin="0,0,0,25"
                                PlaceholderText="Escribe aquí los defectos encontrados o comentarios sobre la revisión..."/>

                    <TextBlock Text="Selecciona tu Veredicto:" FontWeight="SemiBold" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0" Content="Corrección" 
                                   Command="{Binding EmitirVeredictoCommand}" 
                                   CommandParameter="Corrección"
                                   Icon="Dismiss24"
                                   Appearance="Danger" HorizontalAlignment="Stretch" Height="45" FontSize="14" FontWeight="SemiBold"/>

                        <ui:Button Grid.Column="2" Content="Aprobado" 
                                   Command="{Binding EmitirVeredictoCommand}" 
                                   CommandParameter="Aprobado"
                                   Icon="Checkmark24"
                                   Appearance="Success" HorizontalAlignment="Stretch" Height="45" FontSize="14" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>