<UserControl x:Class="ProyectoSoftware.Views.IngenieroDesarrolladorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:viewmodels="clr-namespace:ProyectoSoftware.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:IngenieroDesarrolladorViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Mi Área de Trabajo" FontSize="28" FontWeight="Bold" Foreground="#D5D5D5"/>
            <TextBlock Text="Gestiona el desarrollo de tus actividades asignadas" FontSize="14" Foreground="#999999" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="Black" CornerRadius="8" Padding="10" Opacity="0.6">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1" Color="Black"/>
            </Border.Effect>

            <ui:DataGrid ItemsSource="{Binding MisActividades}" 
                         SelectedItem="{Binding ActividadSeleccionada}"
                         AutoGenerateColumns="False" 
                         IsReadOnly="True"
                         HeadersVisibility="Column">

                <ui:DataGrid.Columns>
                    <DataGridTextColumn Header="Proyecto" Binding="{Binding IdProyecto}" Width="80"/>
                    <DataGridTextColumn Header="Actividad" Binding="{Binding NombreActividad}" Width="*"/>

                    <DataGridTextColumn Header="Fecha de Recepción" Binding="{Binding FechaRecepcion, StringFormat=dd/MM/yyyy HH:mm}" Width="160"/>

                    <DataGridTextColumn Header="Fecha de Culminación" Binding="{Binding FechaCulminacion, StringFormat=dd/MM/yyyy HH:mm}" Width="160"/>

                    <DataGridTemplateColumn Header="Estado" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Background="#F0F4F8">
                                    <TextBlock Text="{Binding Estado}" Foreground="#005FB8" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </ui:DataGrid.Columns>
            </ui:DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Marcar como Terminada" 
                       Command="{Binding CulminarActividadCommand}"
                       Style="{StaticResource NormalButton}"
                       Padding="20,10" FontSize="14"/>
        </StackPanel>
    </Grid>
</UserControl>