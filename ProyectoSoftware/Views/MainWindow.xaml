<ui:FluentWindow x:Class="ProyectoSoftware.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:viewmodels="clr-namespace:ProyectoSoftware.ViewModels"
        xmlns:views="clr-namespace:ProyectoSoftware.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        Title="Sistema de Revisión Técnica Formal"
        mc:Ignorable="d" 
        Height="600" Width="900"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        Background="Transparent">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:GerenciaViewModel}">
            <views:GerenciaView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:LiderViewModel}">
            <views:LiderView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:IngenieroRevisorViewModel}">
            <views:IngenieroRevisorView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:IngenieroDesarrolladorViewModel}">
            <views:IngenieroDesarrolladorView />
        </DataTemplate>
    </Window.Resources>

    <StackPanel>
        <StackPanel.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#201f0000" Offset="0.0" />
                <GradientStop Color="#200000FF" Offset="1.0" />
            </LinearGradientBrush>
        </StackPanel.Background>

        <ui:TitleBar Title="Revisión Técnica Formal"/>

        <ContentControl Content="{Binding CurrentViewModel}" />

            <!--<ui:Card Margin="8">
            <ui:Button Content="Hello World" Icon="{ui:SymbolIcon Fluent24}" />
        </ui:Card>-->
    </StackPanel>
</ui:FluentWindow>