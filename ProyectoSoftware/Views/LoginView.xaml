<UserControl x:Class="ProyectoSoftware.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:viewmodels="clr-namespace:ProyectoSoftware.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:LoginViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">
    <Grid>
        <Border Width="380" Height="460" 
                CornerRadius="16" 
                Padding="35"
                VerticalAlignment="Center" HorizontalAlignment="Center">

            <Border.Background>
                <SolidColorBrush Color="White" Opacity="0.6"/>
            </Border.Background>

            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="5" Opacity="0.15" Color="Black"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">

                <ui:SymbolIcon Symbol="ShieldPerson20" FontSize="48" 
                               Foreground="#005FB8" Margin="0,0,0,15" 
                               HorizontalAlignment="Center"/>

                <TextBlock Text="Revisión Técnica Formal" 
                           FontSize="24" FontWeight="SemiBold" 
                           FontFamily="Segoe UI Variable Display"
                           Margin="0,0,0,5" HorizontalAlignment="Center" 
                           Foreground="#1A1A1A"/>

                <TextBlock Text="Inicia sesión para continuar" 
                           FontSize="14" 
                           Margin="0,0,0,30" HorizontalAlignment="Center" 
                           Foreground="#666666"/>

                <TextBlock Text="Correo Electrónico" FontWeight="Medium" 
                           Foreground="#333" Margin="0,0,0,8"/>

                <!-- CornerRadius eliminado; Icon como elemento hijo -->
                <ui:TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                            PlaceholderText="ejemplo@empresa.com"
                            Height="40" Margin="0,0,0,20" 
                            FontSize="14">
                    <ui:TextBox.Icon>
                        <ui:SymbolIcon Symbol="Person24" />
                    </ui:TextBox.Icon>
                </ui:TextBox>

                <TextBlock Text="Contraseña" FontWeight="Medium" 
                           Foreground="#333" Margin="0,0,0,8"/>

                <!-- CornerRadius eliminado; Icon como elemento hijo -->
                <ui:PasswordBox Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                PlaceholderText="••••••••"
                                Height="40" Margin="0,0,0,35" 
                                FontSize="14">
                    <ui:PasswordBox.Icon>
                        <ui:SymbolIcon Symbol="LockClosed24" />
                    </ui:PasswordBox.Icon>
                </ui:PasswordBox>

                <Button Command="{Binding LoginCommand}" 
                        Height="45" 
                        Foreground="White" 
                        FontSize="16" FontWeight="SemiBold"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" x:Name="BtnBorder">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0078D4" Offset="0.0" />
                                        <GradientStop Color="#005A9E" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#0086F0" Offset="0.0" />
                                                <GradientStop Color="#006CBE" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="Ingresar" />
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>